void handleMainMenuTouch(int x, int y) {
  // Settings button
  if(x > 10 && x < 160 && y > 0 && y < 80) {
    currentScreen = SETTINGS_MENU;
    drawSettingsMenu();
  }
  // Setup button
  if(x > 161 && x < 311 && y > 0 && y < 80) {
    currentScreen = SETUP_MENU;
    drawSetupMenu();
  }
  // Diagnostics button
  if(x > 312 && x < 462 && y > 0 && y < 80) {
    currentScreen = DIAGNOSTICS_MENU;
    drawDiagnosticsMenu();
  }
}

void handleSubmenuTouch(int x, int y) {
  // Back button
  if(x > 0 && x < 80 && y > 0 && y < 40) {
    currentScreen = MAIN_MENU;
    drawMainMenu();
    return;
  }
  // Start Setup button 
  if(currentScreen == SETUP_MENU &&
     x > 150 && x < 330 &&
     y > 80  && y < 160) {

    currentScreen = SETUP_RUNNING;   
    startsetup();                    
    return;
  }

  if(currentScreen == SETUP_RUNNING) {
  // Back to main setup menu
  if(x > 0 && x < 80 && y > 0 && y < 40) {
    currentScreen = SETUP_MENU;
    drawSetupMenu();
    return;
  }
  // NEXT button
  if(x > 300 && x < 420 && y > 200 && y < 240) {
    if(currentSetupPage == SETUP_PAGE_1) currentSetupPage = SETUP_PAGE_2;
    else if(currentSetupPage == SETUP_PAGE_2) currentSetupPage = SETUP_PAGE_3;
    startsetup();
    return;
  }
  // BACK button (only on pages 2 and 3)
  if(x > 150 && x < 270 && y > 200 && y < 240) {
    if(currentSetupPage == SETUP_PAGE_2) currentSetupPage = SETUP_PAGE_1;
    else if(currentSetupPage == SETUP_PAGE_3) currentSetupPage = SETUP_PAGE_2;
    startsetup();
    return;
   }
 }
}

void handleDiagnosticsTouch(int x, int y) {
  // Back button
  if(x > 0 && x < 80 && y > 0 && y < 40) {
    currentScreen = MAIN_MENU;
    drawMainMenu();
    return;
  }
  // STOP button
  if(x > 178 && x < 318 && y > 15 && y < 55) {
    Motor1.stop();
    Motor2.stop();
    Motor3.stop();
    Motor4.stop();
    return;
  }
  // Left Motors button
  if(x > 75 && x < 235 && y > 80 && y < 140) {
    Motor1.spin(forward);
    Motor2.spin(forward);
    Motor3.spin(forward);
    Motor4.spin(forward);
    return;
  }
  // Right Motors button
  if(x > 260 && x < 420 && y > 80 && y < 140) {
    Motor1.spin(reverse);
    Motor2.spin(reverse);
    Motor3.spin(reverse);
    Motor4.spin(reverse);
    return;
  }
  // If touching anywhere else → stop motors
  Motor1.stop();
  Motor2.stop();
  Motor3.stop();
  Motor4.stop();
}

