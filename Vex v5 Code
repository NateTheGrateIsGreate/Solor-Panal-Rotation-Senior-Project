void solorTacking() {
  

  int lightC = LightC.brightness();
  int lightD = LightD.brightness();
  int pos = EncoderA.position(degrees);

  bool atRightLimit = pos >= 360;
  bool atLeftLimit  = pos <= -360;

  // --- MOVE RIGHT (toward +360) ---
  if (lightC > lightD) {

    if (!atRightLimit) {   // allow only if NOT at right limit
      Motor1.spin(forward);
      Motor2.spin(forward);
      Motor3.spin(forward);
      Motor4.spin(forward);
    } else {
      Motor1.stop();
      Motor2.stop();
      Motor3.stop();
      Motor4.stop();
    }
  }

  // --- MOVE LEFT (toward -360) ---
  else if (lightC < lightD) {

    if (!atLeftLimit) {    // allow only if NOT at left limit
      Motor1.spin(reverse);
      Motor2.spin(reverse);
      Motor3.spin(reverse);
      Motor4.spin(reverse);
    } else {
      Motor1.stop();
      Motor2.stop();
      Motor3.stop();
      Motor4.stop();
    }
  }

  // --- BOTH SENSORS BRIGHT OR EQUAL ---
  else if (lightC > 78 && lightD > 78) {
    Motor1.stop();
    Motor2.stop();
    Motor3.stop();
    Motor4.stop();
  }

  else {
    Motor1.stop();
    Motor2.stop();
    Motor3.stop();
    Motor4.stop();
  }
}

void wakeScreen() {
  screenSleeping = false;

  switch(currentScreen) {
    case MAIN_MENU:
      drawMainMenu();
      break;

    case SETTINGS_MENU:
      drawSettingsMenu();
      break;

    case SETUP_MENU:
      drawSetupMenu();
      break;

    case SETUP_RUNNING:   
      startsetup();
      break;

    case DIAGNOSTICS_MENU:
      drawDiagnosticsMenu();
      break;
  }
}

int main() {

  wakeScreen();

  lastActivityTime = Brain.Timer.system(); 

  pwm_out ardrinoCommunication = pwm_out(Brain.ThreeWirePort.A);  
  pwm_out ardrinoCommunication2 = pwm_out(Brain.ThreeWirePort.B);
  

  while(true) {

    Brain.Screen.setFont(mono20);

     double axleDegrees = EncoderA.position(degrees); 
    
    double axlePercent = (axleDegrees / 360.0) * 100.0;
    
    ardrinoCommunication.state(axlePercent, percent); 

    float averageLight = (LightC.brightness() + LightD.brightness()) / 2.0; 

    ardrinoCommunication2.state(averageLight, percent); 



  
    if(Brain.Screen.pressing()) {

      int x = Brain.Screen.xPosition();
      int y = Brain.Screen.yPosition();

      lastActivityTime = Brain.Timer.system();

      if(screenSleeping) {
        wakeScreen();
      } else {

        switch(currentScreen) {

         case MAIN_MENU:
            handleMainMenuTouch(x, y);
            break;

         case SETTINGS_MENU:
         case SETUP_MENU:
           handleSubmenuTouch(x, y);
           break;

         case SETUP_RUNNING: 
           handleSubmenuTouch(x, y);
           break;

         case DIAGNOSTICS_MENU:
          if(Brain.Screen.pressing()) { 
            handleDiagnosticsTouch(x, y);
          } else {
           Motor1.stop();
           Motor2.stop();
           Motor3.stop();
           Motor4.stop();
          }
          
          break;

        }

      }
      wait(200, msec); 
    }

    if (currentScreen == DIAGNOSTICS_MENU && !screenSleeping) {
      updateDiagnosticsData();
    }

    if (currentScreen == SETUP_RUNNING && currentSetupPage == SETUP_PAGE_2) {

      int potValue = PotentiometerE.angle(percent);  
      int diff = potValue - 50;                       
      int steps = abs(diff);                       

      if (diff > 0) {
          
          Motor1.spinFor(forward, steps, degrees, false);
          Motor2.spinFor(forward, steps, degrees, false);
          Motor3.spinFor(forward, steps, degrees, false);
          Motor4.spinFor(forward, steps, degrees, true);
      }
      else if (diff < 0) {
          
          Motor1.spinFor(reverse, steps, degrees, false);
          Motor2.spinFor(reverse, steps, degrees, false);
          Motor3.spinFor(reverse, steps, degrees, false);
          Motor4.spinFor(reverse, steps, degrees, true);
      }
      else {
         
          Motor1.stop();
          Motor2.stop();
          Motor3.stop();
          Motor4.stop();
      }
    }

    if((currentScreen == MAIN_MENU || currentScreen == SETTINGS_MENU || currentScreen == DIAGNOSTICS_MENU)){
      solorTacking();
    }

    // Timeout sleep
    if(!screenSleeping &&
       Brain.Timer.system() - lastActivityTime > screenTimeout) {

      screenSleeping = true;
      Brain.Screen.clearScreen();
    }
    wait(20, msec);
  }
}
